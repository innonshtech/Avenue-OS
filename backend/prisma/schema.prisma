generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  PRINCIPAL_ENGINEER
  ENGINEER
  DRAFTSMAN
  ARCHITECT
  CLIENT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum RFISeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RFIType {
  ARCHITECTURAL_CLARIFICATION
  CLIENT_APPROVAL_PENDING
  SITE_DISCREPANCY
  RESOURCE_UNAVAILABLE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  INTERNAL_REVIEW
  EXTERNAL_REVIEW
  MODIFICATION_REQUIRED
  APPROVED
  DONE
}

enum TargetStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELED
}

enum NotificationType {
  MENTION
  ASSIGNED
  STATUS_CHANGE
  TARGET_STARTED
  TARGET_ENDED
  RFI_ALERT
  SYSTEM
}

enum FeedbackCategory {
  TARGET
  TASK_ASSIGNMENT
  DEADLINE
  COMMUNICATION
  TEAM_COLLABORATION
  PROCESS_IMPROVEMENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole
  department String
  avatar     String?
  isActive   Boolean  @default(true)

  projectsOwned        Project[]               @relation("ProjectOwner")
  tasksAssigned        Task[]                  @relation("TaskAssignee")
  tasksCreated         Task[]                  @relation("TaskCreator")
  comments             Comment[]
  commentReactions     CommentReaction[]
  inAppNotifications   InAppNotification[]
  activities           TaskActivity[]
  enterpriseActivities ActivityLog[]
  progressReports      ProgressReport[]
  rfisReported         RFI[]
  feedbacks            Feedback[]
  notifications        Notification[]
  performanceMetrics   TeamPerformanceMetric[]

  projectMembers ProjectMember[]
  targetMembers   TargetMember[]
  rfisHelped     RFI[]       @relation("RFIHelper")
  focuses        TodayFocus[]
  sessions       UserSession[]

  chatMessages        ChatMessage[]
  messageReactions    MessageReaction[]
  chatMemberships     ChatMember[]
  pinnedMessages      PinnedMessage[]
  createdChannels     ChatChannel[]           @relation("CreatedChannels")
  timesheets          Timesheet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Project {
  id          String        @id @default(uuid())
  key         String        @unique // e.g., "PROJ"
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  deadline    DateTime?
  ownerId     String

  owner User @relation("ProjectOwner", fields: [ownerId], references: [id])

  targets        Target[]
  tasks         Task[]
  members       ProjectMember[]
  targetReports  TargetReport[]
  chatChannels  ChatChannel[]

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProjectMember {
  id        String @id @default(uuid())
  projectId String
  userId    String
  role      String @default("MEMBER") // e.g. LEAD, MEMBER

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Target {
  id        String      @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    TargetStatus @default(PLANNED)
  budgetedHours Float?
  projectId String

  project            Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks              Task[]
  progressReports    ProgressReport[]
  feedbacks          Feedback[]
  retrospectives     RetrospectiveComparison[]
  report             TargetReport?
  performanceMetrics TeamPerformanceMetric[]
  members            TargetMember[]
  chatChannels       ChatChannel[]

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model TargetMember {
  id      String @id @default(uuid())
  targetId String
  userId  String

  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([targetId, userId])
}

model Task {
  id                 String       @id @default(uuid())
  key                String       @unique // e.g., "PROJ-123"
  title              String
  description        String?
  taskCategory       String?      @default("DESIGN") // DESIGN, DRAFTING, STUDY
  type               String       @default("MODELING") // MODELING, ANALYSIS, SITE_CHECK, REVIEW
  status             TaskStatus   @default(PENDING)
  priority           TaskPriority @default(MEDIUM)
  storyPoints        Int?
  estimatedHours     Float?
  actualHours        Float?
  drawingNumber      String?
  revisionNumber     String?
  dueDate            DateTime?
  startDate          DateTime?
  acceptanceCriteria String?
  labels             String[]

  projectId  String
  targetId    String?
  assigneeId String?
  creatorId  String

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  target    Target?  @relation(fields: [targetId], references: [id])
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])

  comments        Comment[]
  activities      TaskActivity[]
  attachments     Attachment[]
  rfis            RFI[]
  subtasks        TaskSubtask[]
  progressReports ProgressReport[]
  chatChannels    ChatChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  archivedById  String?
  completedAt   DateTime?
  completedById String?

  @@index([projectId])
  @@index([assigneeId])
  @@index([targetId])
}

model Comment {
  id               String   @id @default(uuid())
  taskId           String
  userId           String
  parentCommentId  String?
  content          String
  isEdited         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment    Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies          Comment[] @relation("CommentReplies")
  reactions        CommentReaction[]
}

model CommentReaction {
  id               String   @id @default(uuid())
  commentId        String
  userId           String
  emoji            String

  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
}

model TaskSubtask {
  id          String  @id @default(uuid())
  title       String
  isCompleted Boolean @default(false)
  taskId      String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskActivity {
  id       String  @id @default(uuid())
  taskId   String
  userId   String
  action   String // e.g., "STATUS_CHANGED", "ASSIGNEE_CHANGED"
  oldValue String?
  newValue String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProgressReport {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  yesterday String
  today     String
  blockers  String?
  userId    String
  targetId   String
  taskId    String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  target       Target    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reportedRFIs RFI[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, targetId, date])
}

model RFI {
  id          String  @id @default(uuid())
  description String
  isResolved  Boolean @default(false)

  severity                RFISeverity @default(HIGH)
  type                    RFIType     @default(ARCHITECTURAL_CLARIFICATION)
  estimatedResolutionDate DateTime?
  helperId                String?

  taskId           String
  reporterId       String
  progressReportId String?

  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reporter       User            @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  helper         User?           @relation("RFIHelper", fields: [helperId], references: [id])
  progressReport ProgressReport? @relation(fields: [progressReportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resolvedAt     DateTime?
  resolvedById   String?
  resolutionNote String?
  chatChannels   ChatChannel[]
}

model Feedback {
  id        String           @id @default(uuid())
  content   String
  sentiment String? // POSITIVE, NEUTRAL, NEGATIVE
  category  FeedbackCategory @default(TARGET)

  // Specific questions
  wentWell            String?
  wentWrong           String?
  improvement         String?
  realisticPlanning   Boolean @default(true)
  achievableDeadlines Boolean @default(true)
  fairDistribution    Boolean @default(true)
  blockerPatterns     String?

  userId  String
  targetId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TargetReport {
  id             String  @id @default(uuid())
  targetId        String  @unique
  projectId      String
  successRate    Float
  velocity       Int
  completedTasks Int
  pendingTasks   Int
  rfiCount       Int
  summary        String?

  target   Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TeamPerformanceMetric {
  id                 String @id @default(uuid())
  userId             String
  targetId            String
  assignedTasks      Int
  completedTasks     Int
  delayedTasks       Int
  rfisRaised         Int
  avgCompletionTime  Float // in hours
  standupConsistency Float // percentage
  utilizationRate    Float // percentage

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, targetId])
}

model AnalyticsSnapshot {
  id                   String   @id @default(uuid())
  date                 DateTime @default(now())
  totalActiveTasks     Int
  targetCompletionRate  Float
  delayedTasks         Int
  rfisCount            Int
  teamVelocity         Int
  avgCompletionTime    Float
  activeProjects       Int
  teamUtilization      Float
}

model RetrospectiveComparison {
  id       String @id @default(uuid())
  metrics  Json // Stores target velocity, completed points, etc.
  targetId  String

  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Notification {
  id      String           @id @default(uuid())
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)
  linkUrl String?
  userId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Attachment {
  id       String @id @default(uuid())
  fileName String
  fileUrl  String
  fileType String
  fileSize Int
  taskId   String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(uuid())

  userId     String
  action     String // e.g., "CREATED", "UPDATED", "DELETED"
  entityType String // e.g., "PROJECT", "USER"
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())
}

model MemberTargetStats {
  id             String @id @default(uuid())
  userId         String
  targetId        String
  completedTasks Int
  pendingTasks   Int
  storyPoints    Int
  completionRate Float
  rfiCount       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TodayFocus {
  id      String @id @default(uuid())
  userId  String
  content String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ProductivitySnapshot {
  id String @id @default(uuid())

  userId String

  completedTasks    Int
  pendingTasks      Int
  rfis              Int
  productivityScore Float

  createdAt DateTime @default(now())
}

model EmailLog {
  id           String   @id @default(uuid())
  taskId       String?
  recipient    String
  subject      String
  status       String
  provider     String
  errorMessage String?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  actionType  String
  entityType  String
  entityId    String
  title       String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model NotificationHistory {
  id             String   @id @default(uuid())
  type           String
  title          String
  description    String
  senderId       String
  receiverId     String?
  taskId         String?
  targetId        String?
  projectId      String?
  mailSent       Boolean  @default(false)
  deliveryStatus String
  createdAt      DateTime @default(now())
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  isActive         Boolean  @default(true)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model SecurityAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  severity  String
  createdAt DateTime @default(now())
}

model LoginHistory {
  id            String    @id @default(uuid())
  userId        String?
  email         String
  ipAddress     String?
  userAgent     String?
  deviceName    String?
  status        String
  failureReason String?
  loggedInAt    DateTime  @default(now())
  loggedOutAt   DateTime?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model InAppNotification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  type        String
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatChannel {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String // DIRECT, PROJECT, TARGET, TASK, RFI, ANNOUNCEMENT
  projectId   String?
  targetId     String?
  taskId      String?
  rfiId       String?
  createdById String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  createdBy User     @relation("CreatedChannels", fields: [createdById], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  target     Target?   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  rfi       RFI?     @relation(fields: [rfiId], references: [id], onDelete: Cascade)

  messages       ChatMessage[]
  members        ChatMember[]
  pinnedMessages PinnedMessage[]
}

model ChatMessage {
  id              String   @id @default(uuid())
  channelId       String
  senderId        String
  content         String
  messageType     String // TEXT, SYSTEM, TASK_REFERENCE
  parentMessageId String?
  isEdited        Boolean  @default(false)
  editedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  channel       ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender        User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  parentMessage ChatMessage? @relation("ThreadReplies", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies       ChatMessage[] @relation("ThreadReplies")
  reactions     MessageReaction[]
  pinnedMessage PinnedMessage?
}

model MessageReaction {
  id        String @id @default(uuid())
  messageId String
  userId    String
  emoji     String

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ChatMember {
  id         String    @id @default(uuid())
  channelId  String
  userId     String
  joinedAt   DateTime  @default(now())
  lastSeenAt DateTime?

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model PinnedMessage {
  id         String   @id @default(uuid())
  channelId  String
  messageId  String   @unique
  pinnedById String
  createdAt  DateTime @default(now())

  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy  User        @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
}

model Timesheet {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @default(now()) // The day the timesheet is for
  tasksWorkedOn String   // Summary of what was done
  hoursWorked   Float    // Number of hours worked
  notes         String?  // Optional notes

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}
